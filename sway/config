set $mod Mod4
set $left h
set $down j
set $up k
set $right l
set $term urxvt
set $menu "bemenu-run -p '         execute' -b --cw 2 --fn Terminus --tb '#000500' --tf '#ffffff' --fb '#151515' --ff '#ffffff' --nb '#000000' --nf '#ffffff' --fbb '#ffffff' -B 1 --bdr '#000000' --ab '#090909' --af '#aaaaaa' --sf '#ffffff' --hb '#111111' --hf '#00ff00' --cf '#ff00ff' --auto-select"
set $browser qutebrowser
set $file_manager ranger
bindsym Mod4+Shift+Return exec ~/bin/alaex
exec mpd
bindsym $mod+Shift+m exec "urxvt -e ncmpcpp && swaymsg exec for_window [class=ncmpcpp] resize set 1004 686"
bindsym $mod+period exec "mpc next"
bindsym $mod+comma exec "mpc prev"
bindsym $mod+slash exec "mpc toggle"

bindsym $mod+d exec warpd --normal
bindsym $mod+s exec pkill -9 warpd

input "2:7:SynPS/2_Synaptics_TouchPad" {
   events disabled
}

input "2:10:TPPS/2_IBM_TrackPoint" {
    events disabled
}


bar {
status_command ~/.config/sway/status.sh
font "Terminus" 11
status_edge_padding 0
status_padding 0
position top
mode hide
tray_output none
workspace_buttons no
height 13
 colors {
 statusline #ffffff
 background #00000000
    }
}

primary_selection disable

